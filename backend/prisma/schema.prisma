generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "sqlite"
   url      = "file:./prisma/dev.db"
   
  
}
model Formateur{
   id           Int      @id @default(autoincrement())
  nom           String
  prenom        String
  email         String   @unique
  telephone     String
  cin           String
  photo         String  
  cv            String
  specialites   String
  Sessions      Session[] @relation("FormateurSessions")
}

model Formation {
  id            Int    @id @default(autoincrement())
  titre         String
  description   String
  chargeHoraire Int
  programmePdf  String
  niveau        String
  tags          String
  categories    String
  Sessions      Session[]
}
model Session{
  id            Int    @id @default(autoincrement())
  formationId   Int
  formation     Formation  @relation(fields: [formationId], references: [id])    
  formateurs    Formateur[] @relation("FormateurSessions")
  dateDebut     String
  dateFin       String
  description   String
  inscriptions Inscription[]
}

model Candidat{
  id            Int  @id @default(autoincrement())
  nom           String
  prenom        String
  email         String
  inscriptions Inscription[]
  
}

model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String 
}

model Inscription {
  candidatId Int
  sessionId  Int

  candidat   Candidat @relation(fields: [candidatId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id])

  @@id([candidatId, sessionId]) // empêche double inscription
}

  